{
    "name": "auroro/workspaces",
    "description": "Composer plugin for PHP monorepo workspace management — cascading installs, dependency graph, filtering, and cross-worktree linking",
    "type": "composer-plugin",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "auroro/composer": "self.version",
        "composer-plugin-api": "^2.6"
    },
    "require-dev": {
        "composer/composer": "^2.6",
        "friendsofphp/php-cs-fixer": "^3",
        "pestphp/pest": "^4",
        "pestphp/pest-plugin-type-coverage": "^4",
        "phpstan/phpstan": "^2"
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "XDEBUG_MODE=coverage pest --coverage --min=98",
        "test:types": "pest --type-coverage --min=100",
        "analyse": "phpstan analyse",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "class": "Auroro\\Workspaces\\Composer\\Plugin",
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        },
        "split": {
            "target": "next-press/workspaces"
        }
    },
    "autoload": {
        "psr-4": {
            "Auroro\\Workspaces\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Auroro\\Workspaces\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
